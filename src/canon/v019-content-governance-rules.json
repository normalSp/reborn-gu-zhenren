      "requiredTests": [
        "anti_farm_cap",
        "no_recipe_unlock",
        "no_formal_shop"
      ]
    },
    {
      "id": "asset_manifest",
      "label": "asset manifest",
      "runtimeTarget": "doc/art/*manifest.json or src/canon/*visual-assets.json",
      "requiredFields": [
        "id",
        "role",
        "status",
        "source",
        "publicPath",
        "usage",
        "boundary",
        "testSampleIds"
      ],
      "forbiddenFields": [
