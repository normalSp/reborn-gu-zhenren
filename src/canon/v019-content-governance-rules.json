      "id": "economy_rule",
      "label": "economy rule",
      "runtimeTarget": "src/canon/*economy*|*resource*|*market*.json",
      "requiredFields": [
        "id",
        "resourceKind",
        "sourceGate",
        "limitPolicy",
        "blockedEscalations",
        "sourceItemIds",
        "testSampleIds"
      ],
      "forbiddenFields": [
        "completeRecipeUnlock",
        "shopInventory",
        "priceTable",
        "commissionProfit",
        "treasureYellowHeavenTrade"
      ],
      "requiredAuthority": "local_economy_or_refine_engine",
